generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE

  @@map("user_status")
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  VIP

  @@map("customer_status")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("product_status")
}

enum ProductBadge {
  NOVO
  EXCLUSIVO
  BEST_SELLER

  @@map("product_badge")
}

enum ProductFit {
  CLASSIC_FIT
  SLIM_FIT
  SUPER_SLIM

  @@map("product_fit")
}

enum ProductCondition {
  NEW
  SEMI_NEW
  USED

  @@map("product_condition")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED

  @@map("order_status")
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED

  @@map("payment_status")
}

enum ShipmentStatus {
  WAITING
  PREPARING
  SHIPPED
  DELIVERED

  @@map("shipment_status")
}

enum PaymentMethod {
  PIX
  CARD
  BOLETO
  CASH

  @@map("payment_method")
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  LABEL_GENERATED
  RECEIVED
  REJECTED

  @@map("return_status")
}

enum PromotionStatus {
  ACTIVE
  DRAFT
  ENDED

  @@map("promotion_status")
}

enum PromotionPlacement {
  HOME
  CATALOG
  GENERAL

  @@map("promotion_placement")
}

enum PromotionMediaType {
  IMAGE
  GIF

  @@map("promotion_media_type")
}

enum SupportConversationState {
  AUTOMATED
  WAITING_HUMAN
  HUMAN
  RESOLVED

  @@map("support_conversation_state")
}

enum SupportConversationSource {
  SITE
  ADMIN
  WHATSAPP

  @@map("support_conversation_source")
}

enum SupportConversationPriority {
  LOW
  NORMAL
  HIGH

  @@map("support_conversation_priority")
}

enum ChatMessageRole {
  USER
  ASSISTANT
  HUMAN
  SYSTEM

  @@map("chat_message_role")
}

enum ChatMessageStatus {
  SENT
  DELIVERED
  TYPING
  READ

  @@map("chat_message_status")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  LOGIN
  LOGOUT
  EXPORT
  ASSIGN
  OTHER

  @@map("audit_action")
}

enum PaymentProvider {
  STRIPE
  PAGSEGURO
  MERCADO_PAGO
  MANUAL
  MOCK

  @@map("payment_provider")
}

model User {
  id                Int       @id @default(autoincrement())
  name              String    @db.VarChar(255)
  email             String    @unique @db.VarChar(255)
  phone             String?   @db.VarChar(32)
  password_hash     String    @db.VarChar(255)
  is_platform_admin Boolean   @default(false)
  is_active         Boolean   @default(true)
  deleted_at        DateTime?
  email_verified_at DateTime?
  last_login_at     DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  profiles               UserProfile[]
  assigned_conversations SupportConversation[] @relation("conversation_assigned_user")
  sent_messages          SupportMessage[]      @relation("message_sender_user")
  audit_logs             AuditLog[]            @relation("audit_actor_user")
  requested_returns      ReturnRequest[]       @relation("return_request_requested_by_user")
  reviewed_returns       ReturnRequest[]       @relation("return_review_user")
  customer               Customer?             @relation("customer_user")
  orders                 Order[]
  orderEvents            OrderEvent[]
  supportConversations   SupportConversation[]

  @@map("users")
}

model Profile {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(120)
  description String?  @db.Text
  color       String   @default("#3F619C") @db.VarChar(32)
  scope       String   @default("operacao") @db.VarChar(32)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  permissions ProfilePermission[]
  users       UserProfile[]

  @@map("profiles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(120)
  name        String   @db.VarChar(160)
  description String?  @db.Text
  module      String   @db.VarChar(80)
  is_critical Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  profiles ProfilePermission[]

  @@index([module])
  @@map("permissions")
}

model ProfilePermission {
  id            Int      @id @default(autoincrement())
  profileId     Int
  permission_id Int
  created_at    DateTime @default(now())

  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([profileId, permission_id])
  @@index([permission_id])
  @@map("profile_permissions")
}

model UserProfile {
  id          Int      @id @default(autoincrement())
  userId      Int
  profileId   Int
  assigned_at DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([profileId])
  @@map("user_profiles")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(140)
  description String?  @db.Text
  image_url   String?  @db.Text
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id                Int               @id @default(autoincrement())
  category_id       Int
  slug              String            @unique @db.VarChar(160)
  name              String            @db.VarChar(255)
  sku               String?           @unique @db.VarChar(120)
  short_description String?           @db.VarChar(255)
  description       String?           @db.Text
  price             Decimal           @db.Decimal(12, 2)
  old_price         Decimal?          @db.Decimal(12, 2)
  cost_price        Decimal?          @db.Decimal(12, 2)
  rating            Float             @default(0)
  review_count      Int               @default(0)
  badge             ProductBadge?
  fit               ProductFit?
  condition         ProductCondition?
  fabric            String?           @db.VarChar(120)
  is_featured       Boolean           @default(false)
  is_active         Boolean           @default(true)
  status            ProductStatus     @default(PUBLISHED)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  category     Category            @relation(fields: [category_id], references: [id], onDelete: Restrict)
  colors       ProductColor[]
  images       ProductImage[]
  variants     ProductVariant[]
  reviews      ProductReview[]
  order_items  OrderItem[]
  return_items ReturnRequestItem[]

  @@index([category_id])
  @@map("products")
}

model ProductColor {
  id         Int      @id @default(autoincrement())
  product_id Int
  name       String   @db.VarChar(80)
  hex        String   @db.VarChar(16)
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product  Product          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@unique([product_id, name])
  @@index([product_id])
  @@map("product_colors")
}

model ProductImage {
  id         Int      @id @default(autoincrement())
  product_id Int
  url        String   @db.Text
  alt        String?  @db.VarChar(255)
  sort_order Int      @default(0)
  is_primary Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_images")
}

model ProductVariant {
  id               Int      @id @default(autoincrement())
  product_id       Int
  product_color_id Int
  size             String   @db.VarChar(32)
  sku              String   @unique @db.VarChar(120)
  price            Decimal? @db.Decimal(12, 2)
  stock            Int      @default(0)
  reserved_stock   Int      @default(0)
  sort_order       Int      @default(0)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  product     Product      @relation(fields: [product_id], references: [id], onDelete: Cascade)
  color       ProductColor @relation(fields: [product_color_id], references: [id], onDelete: Cascade)
  order_items OrderItem[]

  @@unique([product_id, product_color_id, size])
  @@index([product_id])
  @@index([product_color_id])
  @@map("product_variants")
}

model ProductReview {
  id            Int      @id @default(autoincrement())
  product_id    Int
  customer_id   Int?
  name          String   @db.VarChar(120)
  email         String?  @db.VarChar(255)
  rating        Int
  title         String?  @db.VarChar(160)
  content       String   @db.Text
  status        String   @default("PENDING") @db.VarChar(32)
  helpful_count Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  product  Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)

  @@index([product_id])
  @@map("product_reviews")
}

model Customer {
  id             Int            @id @default(autoincrement())
  code           String         @unique @db.VarChar(32)
  name           String         @db.VarChar(255)
  email          String?        @db.VarChar(255)
  phone          String?        @db.VarChar(32)
  document       String?        @db.VarChar(32)
  status         CustomerStatus @default(ACTIVE)
  total_orders   Int            @default(0)
  total_spent    Decimal        @default(0.0) @db.Decimal(12, 2)
  average_ticket Decimal        @default(0.0) @db.Decimal(12, 2)
  tags           String[]
  notes          String?        @db.Text
  registered_at  DateTime       @default(now())
  last_order_at  DateTime?
  user_id        Int?           @unique

  user          User?                 @relation("customer_user", fields: [user_id], references: [id], onDelete: SetNull)
  addresses     CustomerAddress[]
  orders        Order[]
  reviews       ProductReview[]
  conversations SupportConversation[]
  returns       ReturnRequest[]

  @@map("customers")
}

model CustomerAddress {
  id          Int      @id @default(autoincrement())
  customer_id Int
  label       String   @db.VarChar(80)
  street      String   @db.VarChar(255)
  number      String?  @db.VarChar(32)
  complement  String?  @db.VarChar(120)
  district    String?  @db.VarChar(120)
  city        String   @db.VarChar(120)
  state       String   @db.VarChar(32)
  zip_code    String   @db.VarChar(16)
  is_primary  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@map("customer_addresses")
}

model Order {
  id                  Int            @id @default(autoincrement())
  customer_id         Int?
  user_id             Int?
  number              String         @unique @db.VarChar(32)
  status              OrderStatus    @default(PENDING)
  payment_status      PaymentStatus  @default(PENDING)
  shipment_status     ShipmentStatus @default(WAITING)
  channel             String         @db.VarChar(32)
  payment_method      PaymentMethod?
  subtotal            Decimal        @db.Decimal(12, 2)
  discount            Decimal        @default(0.0) @db.Decimal(12, 2)
  shipping            Decimal        @default(0.0) @db.Decimal(12, 2)
  total               Decimal        @db.Decimal(12, 2)
  coupon_code         String?        @db.VarChar(32)
  notes               String?        @db.Text
  shipping_name       String?        @db.VarChar(255)
  shipping_email      String?        @db.VarChar(255)
  shipping_phone      String?        @db.VarChar(32)
  shipping_zip_code   String?        @db.VarChar(16)
  shipping_street     String?        @db.VarChar(255)
  shipping_number     String?        @db.VarChar(32)
  shipping_complement String?        @db.VarChar(120)
  shipping_district   String?        @db.VarChar(120)
  shipping_city       String?        @db.VarChar(120)
  shipping_state      String?        @db.VarChar(32)
  tracking_code       String?        @db.VarChar(120)
  tracking_url        String?        @db.Text
  placed_at           DateTime?
  paid_at             DateTime?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  customer             Customer?             @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  user                 User?                 @relation(fields: [user_id], references: [id], onDelete: SetNull)
  items                OrderItem[]
  events               OrderEvent[]
  payment              PaymentTransaction?
  shipment             Shipment?
  returns              ReturnRequest[]
  supportConversations SupportConversation[]

  @@index([customer_id])
  @@index([user_id])
  @@map("orders")
}

model OrderItem {
  id                 Int      @id @default(autoincrement())
  order_id           Int
  product_id         Int
  product_variant_id Int?
  product_name       String   @db.VarChar(255)
  product_sku        String?  @db.VarChar(120)
  color_name         String?  @db.VarChar(80)
  size_label         String?  @db.VarChar(32)
  image_url          String?  @db.Text
  quantity           Int
  unit_price         Decimal  @db.Decimal(12, 2)
  total              Decimal  @db.Decimal(12, 2)
  created_at         DateTime @default(now())

  order        Order               @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product      Product             @relation(fields: [product_id], references: [id], onDelete: Restrict)
  variant      ProductVariant?     @relation(fields: [product_variant_id], references: [id], onDelete: SetNull)
  return_items ReturnRequestItem[]

  @@index([order_id])
  @@index([product_id])
  @@index([product_variant_id])
  @@map("order_items")
}

model OrderEvent {
  id            Int          @id @default(autoincrement())
  order_id      Int
  status        OrderStatus?
  description   String       @db.Text
  actor_type    String       @db.VarChar(32)
  actor_user_id Int?
  metadata      Json?
  created_at    DateTime     @default(now())

  order      Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
  actor_user User? @relation(fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([actor_user_id])
  @@map("order_events")
}

model PaymentTransaction {
  id            Int             @id @default(autoincrement())
  order_id      Int             @unique
  method        PaymentMethod
  status        PaymentStatus   @default(PENDING)
  provider      PaymentProvider @default(MOCK)
  amount        Decimal         @db.Decimal(12, 2)
  installments  Int?
  pix_code      String?         @db.Text
  pix_qr_code   String?         @db.Text
  boleto_url    String?         @db.Text
  card_brand    String?         @db.VarChar(32)
  card_last4    String?         @db.VarChar(8)
  card_holder   String?         @db.VarChar(255)
  authorized_at DateTime?
  captured_at   DateTime?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("payment_transactions")
}

model Shipment {
  id            Int            @id @default(autoincrement())
  order_id      Int            @unique
  carrier       String?        @db.VarChar(120)
  service_level String?        @db.VarChar(120)
  tracking_code String?        @db.VarChar(120)
  tracking_url  String?        @db.Text
  label_code    String?        @db.VarChar(120)
  label_url     String?        @db.Text
  status        ShipmentStatus @default(WAITING)
  shipped_at    DateTime?
  delivered_at  DateTime?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("shipments")
}

model ReturnRequest {
  id                   Int          @id @default(autoincrement())
  order_id             Int
  customer_id          Int
  requested_by_user_id Int?
  reviewed_by_user_id  Int?
  order_number         String       @db.VarChar(32)
  reason               String       @db.Text
  details              String?      @db.Text
  status               ReturnStatus @default(REQUESTED)
  label_code           String?      @db.VarChar(120)
  label_url            String?      @db.Text
  requested_at         DateTime     @default(now())
  expires_at           DateTime
  reviewed_at          DateTime?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  order             Order               @relation(fields: [order_id], references: [id], onDelete: Cascade)
  customer          Customer            @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  requested_by_user User?               @relation("return_request_requested_by_user", fields: [requested_by_user_id], references: [id], onDelete: SetNull)
  reviewed_by_user  User?               @relation("return_review_user", fields: [reviewed_by_user_id], references: [id], onDelete: SetNull)
  items             ReturnRequestItem[]

  @@index([order_id])
  @@index([customer_id])
  @@map("return_requests")
}

model ReturnRequestItem {
  id                Int      @id @default(autoincrement())
  return_request_id Int
  order_item_id     Int?
  product_id        Int?
  product_name      String   @db.VarChar(255)
  variant_label     String?  @db.VarChar(120)
  quantity          Int
  unit_price        Decimal  @db.Decimal(12, 2)
  created_at        DateTime @default(now())

  return_request ReturnRequest @relation(fields: [return_request_id], references: [id], onDelete: Cascade)
  order_item     OrderItem?    @relation(fields: [order_item_id], references: [id], onDelete: SetNull)
  product        Product?      @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([return_request_id])
  @@index([order_item_id])
  @@map("return_request_items")
}

model Promotion {
  id         Int                @id @default(autoincrement())
  title      String             @db.VarChar(160)
  subtitle   String             @db.Text
  badge      String             @db.VarChar(80)
  cta_label  String             @db.VarChar(80)
  cta_href   String             @db.VarChar(255)
  media_url  String             @db.Text
  media_type PromotionMediaType @default(IMAGE)
  placement  PromotionPlacement @default(HOME)
  status     PromotionStatus    @default(DRAFT)
  starts_at  DateTime
  ends_at    DateTime
  priority   Int                @default(0)
  audience   String             @db.VarChar(120)
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt

  @@index([status])
  @@index([placement])
  @@map("promotions")
}

model Coupon {
  id                 Int       @id @default(autoincrement())
  code               String    @unique @db.VarChar(32)
  description        String?   @db.Text
  discount_type      String    @db.VarChar(16)
  discount_value     Decimal   @db.Decimal(12, 2)
  minimum_purchase   Decimal?  @db.Decimal(12, 2)
  max_uses           Int?
  uses_count         Int       @default(0)
  per_customer_limit Int?
  starts_at          DateTime?
  ends_at            DateTime?
  status             String    @db.VarChar(32)
  is_active          Boolean   @default(true)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@map("coupons")
}

model SupportConversation {
  id                 Int                         @id @default(autoincrement())
  customer_id        Int?
  user_id            Int?
  customer_name      String                      @db.VarChar(255)
  customer_email     String                      @db.VarChar(255)
  subject            String                      @db.VarChar(255)
  source             SupportConversationSource   @default(SITE)
  state              SupportConversationState    @default(AUTOMATED)
  priority           SupportConversationPriority @default(NORMAL)
  order_id           Int?
  assigned_user_id   Int?
  human_requested_at DateTime?
  resolved_at        DateTime?
  tags               String[]
  last_message_at    DateTime?
  created_at         DateTime                    @default(now())
  updated_at         DateTime                    @updatedAt

  customer      Customer?        @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  user          User?            @relation(fields: [user_id], references: [id], onDelete: SetNull)
  order         Order?           @relation(fields: [order_id], references: [id], onDelete: SetNull)
  assigned_user User?            @relation("conversation_assigned_user", fields: [assigned_user_id], references: [id], onDelete: SetNull)
  messages      SupportMessage[]

  @@index([customer_id])
  @@index([user_id])
  @@index([assigned_user_id])
  @@index([state])
  @@map("support_conversations")
}

model SupportMessage {
  id              Int               @id @default(autoincrement())
  conversation_id Int
  role            ChatMessageRole
  status          ChatMessageStatus @default(DELIVERED)
  content         String            @db.Text
  sender_user_id  Int?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  conversation SupportConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender_user  User?               @relation("message_sender_user", fields: [sender_user_id], references: [id], onDelete: SetNull)

  @@index([conversation_id])
  @@index([sender_user_id])
  @@map("support_messages")
}

model AuditLog {
  id            Int         @id @default(autoincrement())
  actor_user_id Int?
  actor_name    String      @db.VarChar(255)
  action        AuditAction
  entity_type   String      @db.VarChar(80)
  entity_id     String      @db.VarChar(80)
  before        Json?
  after         Json?
  metadata      Json?
  ip_address    String?     @db.VarChar(64)
  created_at    DateTime    @default(now())

  actor_user User? @relation("audit_actor_user", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([actor_user_id])
  @@index([entity_type, entity_id])
  @@map("audit_logs")
}
